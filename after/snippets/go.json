{
  "package main": {
    "prefix": "pkgm",
    "body": ["package main", "", "func main() {", "  $0", "}"],
    "description": "Main package with main function"
  },
  "func": {
    "prefix": "fn",
    "body": ["func ${1:name}($2) ${3:error} {", "  $0", "}"],
    "description": "Function declaration"
  },
  "method": {
    "prefix": "meth",
    "body": ["func (${1:receiver} ${2:Type}) ${3:Method}($4) ${5:error} {", "  $0", "}"],
    "description": "Method declaration"
  },
  "struct": {
    "prefix": "struct",
    "body": ["type ${1:Name} struct {", "  $0", "}"],
    "description": "Struct definition"
  },
  "interface": {
    "prefix": "iface",
    "body": ["type ${1:Name} interface {", "  $0", "}"],
    "description": "Interface definition"
  },
  "for range": {
    "prefix": "forr",
    "body": ["for ${1:idx}, ${2:val} := range ${3:collection} {", "  $0", "}"],
    "description": "For range loop"
  },
  "if err != nil": {
    "prefix": "iferr",
    "body": ["if err != nil {", "  return ${1:err}", "}"],
    "description": "Error check"
  }
}
